# Copy to .env and fill in. .env is gitignored — never commit it.
YNAB_TOKEN=your_personal_access_token_here
# Find IDs via the API: GET https://api.ynab.com/v1/budgets?include_accounts=true
YNAB_BUDGET_ID=your_budget_id_here
YNAB_ACCOUNT_ID=your_tng_account_id_here
# Password used to open the TNG eWallet PDF export
TNG_PDF_PASSWORD=your_pdf_password_here
